

cc_binary {
    name: "android.hardware.thermal@1.0-service.mock",
    defaults: ["hidl_defaults"],
    relative_install_path: "hw",
    vendor: true,
    init_rc: ["android.hardware.thermal@1.0-service.mock.rc"],
    srcs: [
        "Thermal.cpp",
        "service.cpp",
    ],
    shared_libs: [
        "libbase",
        "libhidlbase",
        "libutils",
        "android.hardware.thermal@1.0",
    ],
}
