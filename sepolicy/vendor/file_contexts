# Cutback
/data/vendor/misc/cutback(/.*)?     u:object_r:cutback_data_file:s0
/dev/socket/cutback                 u:object_r:cutback_socket:s0

# Files in rootfs
/bt_firmware(/.*)?       u:object_r:bt_firmware_file:s0
/firmware(/.*)?          u:object_r:firmware_file:s0
/persist(/.*)?           u:object_r:mnt_vendor_file:s0

# Fingerprint
/dev/goodix_fp                                                u:object_r:gx_fpd_device:s0
/data/system/fingerprint(/.*)?                                u:object_r:gx_fpd_data_file:s0
/(vendor|system/vendor)/bin/gx_fpd                            u:object_r:gx_fpd_exec:s0

# MAC Loader
/(vendor|system/vendor)/bin/vendor.blackberry.macloader         u:object_r:macloader_exec:s0

# NFC
/(vendor|system/vendor)/bin/hw/android.hardware.nfc-service.nxp         u:object_r:hal_nfc_default_exec:s0

# Lights service
/(vendor|system/vendor)/bin/hw/android.hardware.lights-service.blackberry                   u:object_r:hal_light_default_exec:s0

# Touch (GloveMode) service
/(vendor|system/vendor)/bin/hw/vendor.lineage.touch@1.0-service.blackberry      u:object_r:hal_lineage_touch_default_exec:s0

# Partitions (Non-A/B)
/dev/block/platform/soc/c0c4000\.sdhci/by-name/storesec                        u:object_r:boot_block_device:s0

# tombstones
/data/vendor/tombstones/rfs(/.*)?      u:object_r:rfs_tombstone_data_file:s0
